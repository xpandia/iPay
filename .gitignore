# ============================================================================
# iPay — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Node.js
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ----------------------------------------------------------------------------
# Next.js
# ----------------------------------------------------------------------------
.next/
out/
.vercel

# ----------------------------------------------------------------------------
# Environment files
# ----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ----------------------------------------------------------------------------
# Rust / Cargo
# ----------------------------------------------------------------------------
target/
**/*.rs.bk
Cargo.lock
!ipay_protocol/Cargo.lock

# ----------------------------------------------------------------------------
# Solana / Anchor
# ----------------------------------------------------------------------------
.anchor/
test-ledger/
*.so
deploy/

# ----------------------------------------------------------------------------
# Build outputs
# ----------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# ----------------------------------------------------------------------------
# Testing / Coverage
# ----------------------------------------------------------------------------
coverage/
.nyc_output/
lcov.info

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.log
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/
